# === Local Development ===
# JWT secret for authentication tokens
JWT_SECRET=change-this-to-a-random-secret

# Server port (local dev only)
PORT=3000

# === Production (Vercel + Turso) ===
# Turso database URL (get from: turso db show <db-name> --url)
# Leave empty for local SQLite file
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io

# Turso auth token (get from: turso db tokens create <db-name>)
# TURSO_AUTH_TOKEN=your-turso-auth-token

# Secret for cron job authentication (set any random string)
# CRON_SECRET=your-random-cron-secret
